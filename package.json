{
  "name": "aiclientjs",
  "version": "0.1.3",
  "description": "The lightweight, universal AI client for JavaScript & TypeScript. Zero dependencies. Works everywhere.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./providers/*": {
      "import": {
        "types": "./dist/providers/*.d.ts",
        "default": "./dist/providers/*.js"
      },
      "require": {
        "types": "./dist/providers/*.d.cts",
        "default": "./dist/providers/*.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "ollama",
    "gpt",
    "claude",
    "streaming",
    "typescript",
    "universal",
    "lightweight"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://amit641.github.io/aiclient/",
  "repository": {
    "type": "git",
    "url": "https://github.com/amit641/aiclient.git"
  },
  "bugs": {
    "url": "https://github.com/amit641/aiclient/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "./src/providers/index.ts",
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
